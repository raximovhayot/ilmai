# Database
DB_URL=jdbc:postgresql://localhost:5432/mydatabase
DB_USERNAME=myuser
DB_PASSWORD=secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=
GOOGLE_CLIENT_ID=

# Google GenAI (chat + embeddings)
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_CHAT_MODEL=gemini-3.1-flash-lite
GOOGLE_GENAI_EMBEDDING_MODEL=gemini-embedding-2
GOOGLE_GENAI_EMBEDDING_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Retrieval (RAG)
RETRIEVAL_TOP_K=6
RETRIEVAL_SIMILARITY_THRESHOLD=0.0

# Object storage (S3 / Garage)
STORAGE_S3_BUCKET=ilmai-materials
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ENDPOINT=http://localhost:3900
STORAGE_S3_ACCESS_KEY=
STORAGE_S3_SECRET_KEY=
STORAGE_S3_PATH_STYLE_ACCESS=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Ingestion
INGESTION_PDF_PAGES_PER_CHUNK=6
INGESTION_PDF_PAGE_OVERLAP=2
INGESTION_AUDIO_WINDOW_MS=120000
INGESTION_AUDIO_OVERLAP_MS=5000

# Plan / notifications
PLAN_BEHIND_THRESHOLD_DAYS=3
NOTIFICATIONS_BROKEN_STREAK_NUDGE_HOUR=8

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PUBLIC_BASE_URL=

# JobRunr
JOBRUNR_BACKGROUND_JOB_SERVER_ENABLED=false
