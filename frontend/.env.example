NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
AUTH_BACKEND_URL=http://localhost:8080

AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

NEXT_PUBLIC_DEMO_MODE=1
# Dev-only sign-in. When "1", the login page shows a "Continue as dev user"
# button that exchanges for REAL backend tokens via POST /auth/dev. The
# backend must also enable it with AUTH_DEV_LOGIN_ENABLED=true (off by
# default). Never enable either flag in production.
NEXT_PUBLIC_DEV_LOGIN=1
NEXT_PUBLIC_MOCK_API=1
# Comma-separated feature ids that should bypass MSW and hit the real backend
# while mock mode is otherwise on. Use "all" to flip every feature live.
# Phase 1 live-integration slice: auth runs through NextAuth -> backend
# regardless of this flag; opt the Companion in here to verify the full
# "sign in -> grounded cited answer" loop against the running Spring backend.
NEXT_PUBLIC_LIVE_FEATURES=companion,telegram,profile,home,quiz,gaps,plan,onboarding,settings,premium

# Sentry error reporting. The SDK stays disabled while the DSN is empty,
# so local dev needs nothing here.
NEXT_PUBLIC_SENTRY_DSN=
# Only needed in CI to upload source maps; the build skips the upload
# gracefully when these are absent.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
