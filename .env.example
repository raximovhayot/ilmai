# Production environment for docker-compose.yml
# Copy to ".env" on the Hetzner VPS (next to docker-compose.yml) and fill in.
# NEVER commit the real ".env" — only this example belongs in git.

# --- Public domain / TLS -----------------------------------------------------
DOMAIN=ilmai.uzinfoweb.uz
# Email used by Caddy for Let's Encrypt registration (optional but recommended).
ACME_EMAIL=admin@uzinfoweb.uz

# --- Container images (overridden by the deploy workflow with a pinned tag) --
BACKEND_IMAGE=ghcr.io/raximovhayot/ilmai-backend:latest
FRONTEND_IMAGE=ghcr.io/raximovhayot/ilmai-frontend:latest

# --- Postgres / pgvector -----------------------------------------------------
POSTGRES_DB=ilmai
POSTGRES_USER=ilmai
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend: auth & AI ------------------------------------------------------
# Base64/long random string used to sign backend-issued JWTs.
JWT_SECRET=change-me-long-random-secret
# Google OAuth client id (must match the frontend AUTH_GOOGLE_ID).
GOOGLE_CLIENT_ID=
# Google Gemini API key for chat + embeddings.
GOOGLE_GENAI_API_KEY=
GOOGLE_GENAI_CHAT_MODEL=gemini-3.1-flash-lite
GOOGLE_GENAI_EMBEDDING_MODEL=gemini-embedding-2

# --- Object storage (Garage, S3-compatible) ----------------------------------
STORAGE_S3_BUCKET=ilmai-materials
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=change-me-access-key
STORAGE_S3_SECRET_KEY=change-me-secret-key
# Garage cluster secrets (hex). Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=change-me-64-hex-chars
GARAGE_ADMIN_TOKEN=change-me-admin-token
GARAGE_METRICS_TOKEN=

# --- Telegram bot (optional; webhook is exposed at https://DOMAIN/telegram/webhook/*) 
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# Defaults to https://${DOMAIN} when left empty.
TELEGRAM_PUBLIC_BASE_URL=

# --- Sentry (errors-only; disabled while DSN is empty) -----------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# --- Frontend (Next.js / NextAuth) -------------------------------------------
# Random string: openssl rand -base64 32
AUTH_SECRET=change-me-random-base64
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
